# Instinct App Environment Variables

# The URL of the Google Apps Script Web App that handles form submissions
# Paste your deployed Google Web App URL here (e.g. https://script.google.com/macros/s/AKfycb.../exec)
SHEETS_API_URL=

# Secret key used for signing and verifying captchas. Use a long random string.
CAPTCHA_SECRET=

# The port the backend server runs on
PORT=5000
